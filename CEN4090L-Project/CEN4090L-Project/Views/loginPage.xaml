<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="CEN4090L_Project.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:CEN4090L_Project.ViewModels"
    Title="Login">

    <ContentPage.BindingContext>
        <vm:LoginViewModel />
    </ContentPage.BindingContext>

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="20" VerticalOptions="Center">

            <!-- App logo or title -->
            <Label Text="College Companion"
                   FontSize="32"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="#3B3B3B"/>

            <Label Text="Sign in to continue"
                   FontSize="14"
                   HorizontalOptions="Center"
                   TextColor="#666"/>

            <!-- Username field -->
            <VerticalStackLayout Spacing="6">
                <Label Text="Username" FontSize="14" />
                <Entry Placeholder="Enter your username"
                       Text="{Binding Username}"
                       Keyboard="Default"
                       ClearButtonVisibility="WhileEditing"/>
            </VerticalStackLayout>

            <!-- Password field -->
            <VerticalStackLayout Spacing="6">
                <Label Text="Password" FontSize="14" />
                <Entry Placeholder="Enter your password"
                       Text="{Binding Password}"
                       IsPassword="True"
                       ClearButtonVisibility="WhileEditing"/>
            </VerticalStackLayout>

            <!-- Login button -->
            <Button Text="Login"
                    Command="{Binding LoginCommand}"
                    BackgroundColor="#4B9EF7"
                    TextColor="White"
                    CornerRadius="8"
                    FontAttributes="Bold"
                    HeightRequest="45"/>

            <!-- Register / Forgot Password links -->
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="8">
                <Label Text="Don't have an account?" FontSize="13" />
                <Label Text="Register"
                       TextColor="#4B9EF7"
                       FontAttributes="Bold">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding RegisterCommand}" />
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

            <Label Text="Forgot Password?"
                   HorizontalOptions="Center"
                   FontSize="13"
                   TextColor="#4B9EF7">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding ForgotPasswordCommand}" />
                </Label.GestureRecognizers>
            </Label>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>