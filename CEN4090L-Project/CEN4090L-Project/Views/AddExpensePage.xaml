<?xml version="1.0" encoding="utf-8" ?>
<ContentPage 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="CEN4090L_Project.Views.AddExpensePage"
    Title="Add Expense">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="18">

            <!-- Title -->
            <Label Text="Add Expense"
                   FontAttributes="Bold"
                   FontSize="24"
                   HorizontalOptions="Start" />

            <!-- Category Section -->
            <Label Text="Category"
       FontAttributes="Bold"
       FontSize="16" />
            <HorizontalStackLayout Spacing="10">
                <Button Text="Needs"
            WidthRequest="100"
            HeightRequest="50"
            CornerRadius="10"
            Command="{Binding SelectCategoryCommand}"
            CommandParameter="Needs">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button" 
                        Binding="{Binding NeedsSelected}" 
                        Value="True">
                            <Setter Property="BackgroundColor" Value="#3B82F6" />
                            <Setter Property="TextColor" Value="White" />
                        </DataTrigger>
                        <DataTrigger TargetType="Button" 
                        Binding="{Binding NeedsSelected}" 
                        Value="False">
                            <Setter Property="BackgroundColor" Value="#E5E7EB" />
                            <Setter Property="TextColor" Value="#1F2937" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>

                <Button Text="Wants"
            WidthRequest="100"
            HeightRequest="50"
            CornerRadius="10"
            Command="{Binding SelectCategoryCommand}"
            CommandParameter="Wants">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button" 
                        Binding="{Binding WantsSelected}" 
                        Value="True">
                            <Setter Property="BackgroundColor" Value="#F59E0B" />
                            <Setter Property="TextColor" Value="White" />
                        </DataTrigger>
                        <DataTrigger TargetType="Button" 
                        Binding="{Binding WantsSelected}" 
                        Value="False">
                            <Setter Property="BackgroundColor" Value="#E5E7EB" />
                            <Setter Property="TextColor" Value="#1F2937" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>

                <Button Text="Savings"
            WidthRequest="100"
            HeightRequest="50"
            CornerRadius="10"
            Command="{Binding SelectCategoryCommand}"
            CommandParameter="Savings">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button" 
                        Binding="{Binding SavingsSelected}" 
                        Value="True">
                            <Setter Property="BackgroundColor" Value="#10B981" />
                            <Setter Property="TextColor" Value="White" />
                        </DataTrigger>
                        <DataTrigger TargetType="Button" 
                        Binding="{Binding SavingsSelected}" 
                        Value="False">
                            <Setter Property="BackgroundColor" Value="#E5E7EB" />
                            <Setter Property="TextColor" Value="#1F2937" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
            </HorizontalStackLayout>

            <!-- Description -->
            <Label Text="Description"
                   FontAttributes="Bold"
                   FontSize="16" />
            <Entry Placeholder="e.g., Groceries, Netflix, Savings deposit"
                   Text="{Binding Description}" />

            <!-- Amount and Date -->
            <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
                <VerticalStackLayout Grid.Column="0">
                    <Label Text="Amount"
                           FontAttributes="Bold"
                           FontSize="16" />
                    <Entry Placeholder="$ 0.00"
                           Keyboard="Numeric"
                           Text="{Binding Amount}" />
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="1">
                    <Label Text="Date"
                           FontAttributes="Bold"
                           FontSize="16" />
                    <DatePicker Date="{Binding Date}" />
                </VerticalStackLayout>
            </Grid>

            <!-- Add Button -->
            <Button Text="Add Expense"
                    FontSize="18"
                    TextColor="White"
                    BackgroundColor="#3B82F6"
                    CornerRadius="12"
                    HeightRequest="50"
                    Command="{Binding SaveExpenseCommand}"
                    Margin="0,20,0,0" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
